# Variables de build para GitHub Pages (HCHAPS404/Proyecto-PRORA).
# En el repositorio GitHub → Settings → Secrets and variables → Actions → Variables:
#
#   PRORA_PAGES_BASE_PATH = /Proyecto-PRORA/
#   PRORA_API_BASE_URL    = https://SU-API-PUBLICA/api/v1
#
# Sin PRORA_API_BASE_URL el frontend se publica en modo invitado (sin backend).
# GitHub Pages NO ejecuta FastAPI, PostgreSQL ni el worker.

VITE_BASE_PATH=/Proyecto-PRORA/
VITE_API_BASE_URL=
