# Copie este archivo como .env. No almacene secretos reales en el repositorio.
PRORA_ENVIRONMENT=development
PRORA_DEBUG=false
PRORA_API_PREFIX=/api/v1
PRORA_DATABASE_URL=sqlite+aiosqlite:///./prora.db
# Produccion: postgresql+asyncpg://USUARIO:CLAVE@HOST:5432/prora
PRORA_AUTO_CREATE_TABLES=true

# Obligatorio en produccion. Genere una clave aleatoria en su gestor de secretos.
PRORA_JWT_SECRET=
PRORA_JWT_ALGORITHM=HS256
PRORA_ACCESS_TOKEN_MINUTES=15
PRORA_REFRESH_TOKEN_DAYS=14

# Lista JSON de origenes autorizados.
PRORA_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
PRORA_RATE_LIMIT_REQUESTS=120
PRORA_RATE_LIMIT_WINDOW_SECONDS=60
PRORA_LOG_LEVEL=INFO

# Datos Abiertos Colombia. El token es opcional en local, recomendado en jobs programados.
PRORA_SOCRATA_APP_TOKEN=
# Sin valor por defecto: el catálogo nacional INS requiere solicitud o una
# publicación agregada aprobada. No use una publicación local como nacional.
PRORA_SIVIGILA_DATASET_ID=
PRORA_PAI_DATASET_ID=6i25-2hdt
PRORA_IDEAM_CLIMATE_DATASET_ID=57sv-p2fu

# Sin valor por defecto: habilite solo despues de validar una tabla y su esquema.
PRORA_IDEAM_DEFORESTATION_DATASET_ID=
PRORA_IDEAM_DEFORESTATION_YEAR_FIELD=ano
PRORA_DANE_SOCIOECONOMIC_DATASET_ID=
PRORA_DANE_YEAR_FIELD=ano

# Ingesta, artefactos y agente analítico opcional.
PRORA_INGESTION_BATCH_SIZE=10000
PRORA_INSTITUTIONAL_UPLOAD_DIR=./data/inbox
PRORA_RAW_SNAPSHOT_DIR=./data/raw
PRORA_MODEL_REGISTRY_PATH=./artifacts/models
PRORA_OPENAI_API_KEY=
PRORA_OPENAI_MODEL=gpt-5.4-mini
PRORA_OPENAI_BASE_URL=https://api.openai.com/v1
