# Copie este archivo como .env. Todos los valores son ejemplos locales;
# no contiene credenciales reales y no debe reutilizarse sin rotacion en produccion.

# Puertos publicados por Docker Compose
PRORA_WEB_PORT=8080
PRORA_API_PORT=8000
POSTGRES_PORT=5432

# Base de datos
POSTGRES_DB=prora
POSTGRES_USER=prora
POSTGRES_PASSWORD=replace-before-production

# Seguridad y operacion
# Desarrollo local: development. Despliegue real: production (exige JWT >= 32 chars).
PRORA_ENVIRONMENT=development
PRORA_JWT_SECRET=replace-this-development-key-with-at-least-32-characters
# En producción liste el origen HTTPS exacto del frontend, sin comodines.
PRORA_CORS_ORIGINS=["http://localhost:8080"]
PRORA_LOG_LEVEL=INFO
PRORA_IMAGE_TAG=local
PRORA_RAW_SNAPSHOT_DIR=/app/data/raw

# La imagen completa instala ML, LSTM y explicabilidad. Use "ml" si desea
# una imagen de API liviana (recomendado en hosts con poca RAM/disco).
PRORA_BACKEND_EXTRAS=ml,lstm,explainability

# Conectores opcionales. Solicite tokens o accesos a la entidad responsable.
PRORA_SOCRATA_APP_TOKEN=

# Agente opcional. Sin esta llave, PRORA conserva respuestas deterministas
# basadas exclusivamente en datos agregados de la base de datos.
PRORA_OPENAI_API_KEY=
PRORA_OPENAI_MODEL=gpt-5.4-mini

# Desarrollo sin Docker: la URL se incorpora durante el build de Vite.
VITE_API_BASE_URL=http://localhost:8000/api/v1
